<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-background-color:#f5f7fb;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.capstonepitogo.GymMembership.DashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70" spacing="20" style="-fx-background-color:#1e3a8a;">

            <padding>
                <Insets bottom="15" left="25" right="25" top="15" />
            </padding>

            <Label style="-fx-text-fill:white;-fx-font-size:24px;-fx-font-weight:bold;" text="🏋 Gym Membership System" />

            <Region HBox.hgrow="ALWAYS" />

            <Button onAction="#handleLogout" style="-fx-background-color:#dc2626;-fx-text-fill:white;-fx-font-weight:bold;" text="Logout" />
        </HBox>
    </top>

    <center>

        <VBox spacing="25">

            <padding>
                <Insets bottom="25" left="25" right="25" top="25" />
            </padding>

            <Label style="-fx-font-size:30px;-fx-font-weight:bold;" text="Dashboard" />

            <Label style="-fx-font-size:16px;-fx-text-fill:#6b7280;" text="Welcome back, Administrator!" />


            <HBox spacing="20">

                <VBox prefWidth="200" spacing="10" style="-fx-background-color:white;-fx-background-radius:10;-fx-padding:20;">
                    <Label text="Members" />
                    <Label fx:id="membersLabel" style="-fx-font-size:28px;-fx-font-weight:bold;" text="0" />
                </VBox>

                <VBox prefWidth="200" spacing="10" style="-fx-background-color:white;-fx-background-radius:10;-fx-padding:20;">
                    <Label text="Active Memberships" />
                    <Label fx:id="membershipLabel" style="-fx-font-size:28px;-fx-font-weight:bold;" text="0" />
                </VBox>

            </HBox>


            <Label style="-fx-font-size:20px;-fx-font-weight:bold;" text="Quick Actions" />

            <HBox spacing="20">

                <Button onAction="#openMembers" prefHeight="50" prefWidth="180" text="+ Add Member" />

                <Button onAction="#openPayments" prefHeight="50" prefWidth="180" text="- Remove Member" />

                <Button onAction="#openPlans" prefHeight="50" prefWidth="180" text="Members" />

            </HBox>


            <Label style="-fx-font-size:20px;-fx-font-weight:bold;" text="Recent Activity" />

            <TableView fx:id="activityTable">

                <columns>

                    <TableColumn prefWidth="220" text="Member" />

                    <TableColumn prefWidth="250" text="Activity" />

                    <TableColumn prefWidth="180" text="Date" />

                </columns>

            </TableView>

        </VBox>

    </center>

</BorderPane>
