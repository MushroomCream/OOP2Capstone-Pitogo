<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.capstonepitogo.GymMembership.WelcomeController">

    <top>
        <VBox alignment="CENTER" spacing="10">
            <padding>
                <Insets bottom="20" left="20" right="20" top="30" />
            </padding>

            <Label style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="GYM MEMBERSHIP SYSTEM" />

            <Label style="-fx-font-size: 14px; -fx-text-fill: #64748b;" text="Manage Members, Membership Plans, and Fitness Goals Efficiently" />
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="25">

            <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Welcome to Your Fitness Management Solution" />

            <Label alignment="CENTER" maxWidth="600" prefHeight="35.0" prefWidth="532.0" style="-fx-font-size: 13px; -fx-text-alignment: center;" text="Track memberships, manage trainers, monitor attendance, and grow your fitness community." wrapText="true" />
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="20">
            <padding>
                <Insets bottom="30" left="20" right="20" top="20" />
            </padding>

            <Button fx:id="loginButton" onAction="#handleLogin" prefWidth="120" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold;" text="Login" />

            <Button fx:id="registerButton" onAction="#handleRegister" prefWidth="120" style="-fx-background-color: #16a34a; -fx-text-fill: white; -fx-font-weight: bold;" text="Register" />

            <Button fx:id="exitButton" onAction="#handleExit" prefWidth="120" style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-font-weight: bold;" text="Exit" />
        </HBox>
    </bottom>

</BorderPane>
