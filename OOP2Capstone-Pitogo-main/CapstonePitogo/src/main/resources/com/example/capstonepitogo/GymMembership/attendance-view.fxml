<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.capstonepitogo.GymMembership.AttendanceController">
    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>

    <Label text="Member Attendance Log">
        <font><Font name="System Bold" size="24.0" /></font>
    </Label>

    <TableView fx:id="attendanceTable" prefHeight="300.0" prefWidth="600.0">
        <columns>
            <TableColumn fx:id="idColumn" prefWidth="50.0" text="Log ID" />
            <TableColumn fx:id="memberColumn" prefWidth="300.0" text="Member Name" />
            <TableColumn fx:id="timeColumn" prefWidth="250.0" text="Check-In Time" />
        </columns>
    </TableView>

    <Button text="Back to Dashboard" onAction="#handleBack" prefWidth="150.0" />
</VBox>