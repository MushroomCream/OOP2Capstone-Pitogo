<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.capstonepitogo.GymMembership.LoginController">

    <center>
        <VBox alignment="CENTER" spacing="20">

            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <Label text="GYM MEMBERSHIP SYSTEM"
                   style="-fx-font-size: 28px; -fx-font-weight: bold;" />

            <Label text="Administrator Login"
                   style="-fx-font-size: 18px;" />

            <GridPane hgap="15" vgap="15">

                <Label text="Username:"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="0"/>

                <TextField fx:id="usernameField"
                           promptText="Enter username"
                           prefWidth="250"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="0"/>

                <Label text="Password:"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="1"/>

                <PasswordField fx:id="passwordField"
                               promptText="Enter password"
                               prefWidth="250"
                               GridPane.columnIndex="1"
                               GridPane.rowIndex="1"/>

            </GridPane>

            <Label fx:id="messageLabel"
                   text=""
                   style="-fx-text-fill: red;" />

            <HBox alignment="CENTER" spacing="20">

                <Button text="Login"
                        prefWidth="120"
                        onAction="#handleLogin"
                        style="-fx-background-color:#2563eb; -fx-text-fill:white;"/>

                <Button text="Back"
                        prefWidth="120"
                        onAction="#handleBack"
                        style="-fx-background-color:#6b7280; -fx-text-fill:white;"/>

            </HBox>

        </VBox>

    </center>

</BorderPane>