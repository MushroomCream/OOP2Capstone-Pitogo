<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.capstonepitogo.GymMembership.RegisterController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label text="Register New Account">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <ComboBox fx:id="roleComboBox" promptText="Select Role" maxWidth="250" />
    <TextField fx:id="fullNameField" promptText="Full Name" maxWidth="250" />
    <TextField fx:id="usernameField" promptText="Username" maxWidth="250" />
    <PasswordField fx:id="passwordField" promptText="Password" maxWidth="250" />
    <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password" maxWidth="250" />

    <Label fx:id="messageLabel" />

    <Button text="Register" onAction="#handleRegister" prefWidth="250" />
    <Button text="Back to Welcome" onAction="#handleBack" prefWidth="250" />

</VBox>