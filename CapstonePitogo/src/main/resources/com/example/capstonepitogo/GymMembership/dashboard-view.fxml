<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.capstonepitogo.GymMembership.DashboardController"
            style="-fx-background-color:#f5f7fb;">

    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="20"
              style="-fx-background-color:#1e3a8a;"
              prefHeight="70">

            <padding>
                <Insets top="15" right="25" bottom="15" left="25"/>
            </padding>

            <Label text="🏋 Gym Membership System"
                   style="-fx-text-fill:white;-fx-font-size:24px;-fx-font-weight:bold;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Logout"
                    onAction="#handleLogout"
                    style="-fx-background-color:#dc2626;-fx-text-fill:white;-fx-font-weight:bold;"/>
        </HBox>
    </top>

    <center>

        <VBox spacing="25">

            <padding>
                <Insets top="25" right="25" bottom="25" left="25"/>
            </padding>

            <Label text="Dashboard"
                   style="-fx-font-size:30px;-fx-font-weight:bold;"/>

            <Label text="Welcome back, Administrator!"
                   style="-fx-font-size:16px;-fx-text-fill:#6b7280;"/>


            <HBox spacing="20">

                <VBox spacing="10"
                      prefWidth="200"
                      style="-fx-background-color:white;-fx-background-radius:10;-fx-padding:20;">
                    <Label text="Members"/>
                    <Label fx:id="membersLabel"
                           text="0"
                           style="-fx-font-size:28px;-fx-font-weight:bold;"/>
                </VBox>

                <VBox spacing="10"
                      prefWidth="200"
                      style="-fx-background-color:white;-fx-background-radius:10;-fx-padding:20;">
                    <Label text="Active Memberships"/>
                    <Label fx:id="membershipLabel"
                           text="0"
                           style="-fx-font-size:28px;-fx-font-weight:bold;"/>
                </VBox>

                <VBox spacing="10"
                      prefWidth="200"
                      style="-fx-background-color:white;-fx-background-radius:10;-fx-padding:20;">
                    <Label text="Today's Check-ins"/>
                    <Label fx:id="attendanceLabel"
                           text="0"
                           style="-fx-font-size:28px;-fx-font-weight:bold;"/>
                </VBox>

                <VBox spacing="10"
                      prefWidth="200"
                      style="-fx-background-color:white;-fx-background-radius:10;-fx-padding:20;">
                    <Label text="Revenue"/>
                    <Label fx:id="revenueLabel"
                           text="0"
                           style="-fx-font-size:28px;-fx-font-weight:bold;"/>
                </VBox>

            </HBox>


            <Label text="Quick Actions"
                   style="-fx-font-size:20px;-fx-font-weight:bold;"/>

            <HBox spacing="20">

                <Button text="Members"
                        prefWidth="180"
                        prefHeight="50"
                        onAction="#openMembers"/>

                <Button text="Membership Plans"
                        prefWidth="180"
                        prefHeight="50"
                        onAction="#openPlans"/>

                <Button text="Attendance"
                        prefWidth="180"
                        prefHeight="50"
                        onAction="#openAttendance"/>

                <Button text="Payments"
                        prefWidth="180"
                        prefHeight="50"
                        onAction="#openPayments"/>

            </HBox>


            <Label text="Recent Activity"
                   style="-fx-font-size:20px;-fx-font-weight:bold;"/>

            <TableView fx:id="activityTable">

                <columns>

                    <TableColumn text="Member"
                                 prefWidth="220"/>

                    <TableColumn text="Activity"
                                 prefWidth="250"/>

                    <TableColumn text="Date"
                                 prefWidth="180"/>

                </columns>

            </TableView>

        </VBox>

    </center>

</BorderPane>