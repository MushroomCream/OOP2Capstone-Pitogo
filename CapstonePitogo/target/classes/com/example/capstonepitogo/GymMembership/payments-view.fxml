<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.capstonepitogo.GymMembership.PaymentsController">
    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>

    <Label text="Payment Records">
        <font><Font name="System Bold" size="24.0" /></font>
    </Label>

    <TableView fx:id="paymentsTable" prefHeight="300.0" prefWidth="600.0">
        <columns>
            <TableColumn fx:id="idColumn" prefWidth="50.0" text="ID" />
            <TableColumn fx:id="memberColumn" prefWidth="250.0" text="Member Name" />
            <TableColumn fx:id="amountColumn" prefWidth="150.0" text="Amount ($)" />
            <TableColumn fx:id="dateColumn" prefWidth="150.0" text="Date" />
        </columns>
    </TableView>

    <Button text="Back to Dashboard" onAction="#handleBack" prefWidth="150.0" />
</VBox>